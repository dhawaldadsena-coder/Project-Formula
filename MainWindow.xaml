<Window x:Class="F1TrackMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="F1 Track Mapper"
        Width="1360"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0A0B0E"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBlackBrush" Color="#0A0B0E" />
        <SolidColorBrush x:Key="AppRedBrush" Color="#E10600" />
        <SolidColorBrush x:Key="AppRedSoftBrush" Color="#7AE10600" />
        <SolidColorBrush x:Key="AppPanelBrush" Color="#242B35" />
        <SolidColorBrush x:Key="AppPanelRaisedBrush" Color="#303743" />
        <SolidColorBrush x:Key="AppPanelAltBrush" Color="#20262F" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#45FFFFFF" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#F8FAFD" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="#C1CAD5" />
        <SolidColorBrush x:Key="AppTextSoftBrush" Color="#95A1AF" />
        <SolidColorBrush x:Key="AppTrackShellBrush" Color="#11161E" />
        <SolidColorBrush x:Key="AppAccentContrastBrush" Color="#070707" />
        <SolidColorBrush x:Key="AppTrackOutlineBrush" Color="#0F1319" />
        <SolidColorBrush x:Key="AppTrackGlowBrush" Color="#3AE10600" />
        <SolidColorBrush x:Key="AppTrackLaneBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="AppTrackEdgeBrush" Color="#18202B" />
        <SolidColorBrush x:Key="AppTurnCardBrush" Color="#D9141820" />
        <SolidColorBrush x:Key="AppPitBaseBrush" Color="#6F5310" />
        <SolidColorBrush x:Key="AppPitDashBrush" Color="#FFC84A" />
        <SolidColorBrush x:Key="AppCanvasFrameBrush" Color="#20FFFFFF" />

        <LinearGradientBrush x:Key="WindowBackdropBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#11161D" Offset="0" />
            <GradientStop Color="#1C2430" Offset="0.42" />
            <GradientStop Color="#0F141B" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2C3440" Offset="0" />
            <GradientStop Color="#222A34" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeroPanelBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#353E4B" Offset="0" />
            <GradientStop Color="#222A34" Offset="0.7" />
            <GradientStop Color="#1E252E" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardShellStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="BodyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ZoomButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Background" Value="{DynamicResource AppPanelRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="#32FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="StatPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource AppPanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="#20FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource WindowBackdropBrush}">
        <Grid Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="324" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="348" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,18,0"
                    Padding="0"
                    Style="{StaticResource CardShellStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="22,20,22,18"
                            Background="{DynamicResource HeroPanelBrush}"
                            BorderBrush="{DynamicResource AppRedSoftBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="24,24,0,0">
                        <StackPanel>
                            <Border Width="82"
                                    Height="6"
                                    HorizontalAlignment="Left"
                                    CornerRadius="3"
                                    Background="{DynamicResource AppRedBrush}" />
                            <TextBlock Margin="0,16,0,0"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Text="F1 Track Mapper" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyStyle}"
                                       Text="Real circuit geometry, team-branded driver chips, and a race-control layout inspired by Formula 1 broadcast graphics." />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="22,18,22,22">
                            <Border Padding="18"
                                    Style="{StaticResource CardShellStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Race Weekend" />
                                    <ComboBox Margin="0,12,0,0"
                                              Padding="10,7"
                                              Background="{DynamicResource AppPanelRaisedBrush}"
                                              Foreground="{DynamicResource AppTextBrush}"
                                              BorderBrush="#35FFFFFF"
                                              BorderThickness="1"
                                              ItemsSource="{Binding Weekends}"
                                              SelectedItem="{Binding SelectedWeekend}"
                                              DisplayMemberPath="DisplayName" />
                                    <TextBlock Margin="0,14,0,0"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               Text="{Binding FocusWeekendName}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               Text="{Binding FocusWeekendDate}" />
                                    <Border Margin="0,14,0,0"
                                            Padding="10,8"
                                            CornerRadius="12"
                                            Background="{DynamicResource AppRedSoftBrush}">
                                        <TextBlock Foreground="#FFE2E0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding CalendarSelectionNote}" />
                                    </Border>

                                    <Button Margin="0,14,0,0"
                                            Padding="12,9"
                                            Click="TelemetryToggle_Click"
                                            Background="{DynamicResource AppPanelRaisedBrush}"
                                            Foreground="{DynamicResource AppTextBrush}"
                                            BorderBrush="{DynamicResource AppRedBrush}"
                                            BorderThickness="1"
                                            FontWeight="Bold"
                                            Content="{Binding TelemetryToggleLabel}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TelemetryToggleCaption}" />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Style="{StaticResource CardShellStyle}">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Text="Theme Garage" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,4"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppRedSoftBrush}">
                                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Text="COOLORS SETS" />
                                        </Border>
                                    </DockPanel>
                                    <ComboBox x:Name="ThemeSelector"
                                              Margin="0,12,0,0"
                                              Padding="10,7"
                                              Background="{DynamicResource AppPanelRaisedBrush}"
                                              Foreground="{DynamicResource AppTextBrush}"
                                              BorderBrush="#35FFFFFF"
                                              BorderThickness="1"
                                              SelectionChanged="ThemeSelector_SelectionChanged">
                                        <ComboBoxItem Tag="RossoCarbon" Content="Rosso Carbon" />
                                        <ComboBoxItem Tag="GraphiteGold" Content="Graphite Gold" />
                                        <ComboBoxItem Tag="AquaVelocity" Content="Aqua Velocity" />
                                        <ComboBoxItem Tag="IceCircuit" Content="Ice Circuit" />
                                        <ComboBoxItem Tag="EmeraldNight" Content="Emerald Night" />
                                        <ComboBoxItem Tag="SunsetGrid" Content="Sunset Grid" />
                                        <ComboBoxItem Tag="VioletKerb" Content="Violet Kerb" />
                                        <ComboBoxItem Tag="ArcticSignal" Content="Arctic Signal" />
                                    </ComboBox>
                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                        <Border Width="42"
                                                Height="16"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppPanelBrush}" />
                                        <Border Width="42"
                                                Height="16"
                                                Margin="8,0,0,0"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppRedBrush}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,12,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="Choose from preloaded two-tone palettes inspired by Coolors-style combinations and tuned for this race-control layout." />
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Style="{StaticResource CardShellStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Circuit Notes" />
                                    <TextBlock Margin="0,12,0,0"
                                               FontSize="27"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               Text="{Binding SelectedCircuitName}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedCircuitSummary}" />

                                    <WrapPanel Margin="0,16,0,0">
                                        <Border Style="{StaticResource StatPillStyle}">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource AppTextSoftBrush}"
                                                           FontSize="11"
                                                           Text="Track State" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding FeedStatusBadge}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource StatPillStyle}">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource AppTextSoftBrush}"
                                                           FontSize="11"
                                                           Text="Stats" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{DynamicResource AppTextBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding TrackStatsLine}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Margin="0,16,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="{Binding TelemetryModeText}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Style="{StaticResource CardShellStyle}">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   Style="{StaticResource SectionTitleStyle}"
                                                   Text="Map Markers" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,4"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppRedSoftBrush}">
                                            <TextBlock Foreground="#FFF2F1"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Text="LIVE STYLE" />
                                        </Border>
                                    </DockPanel>

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding SectorCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="12"
                                                        Background="{DynamicResource AppPanelRaisedBrush}"
                                                        CornerRadius="16"
                                                        BorderBrush="#18FFFFFF"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="48" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Width="42"
                                                                Height="42"
                                                                CornerRadius="12"
                                                                Background="{Binding AccentBrush}">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource AppAccentContrastBrush}"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding Title}" />
                                                        </Border>

                                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Subtitle}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Style="{StaticResource BodyStyle}"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding Description}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0"
                                    Padding="18"
                                    Style="{StaticResource CardShellStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Legend" />
                                    <TextBlock Margin="0,12,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="Driver tags stay compact and team-branded so the circuit outline remains readable even on tighter tracks." />
                                    <TextBlock Margin="0,8,0,0"
                                               Style="{StaticResource BodyStyle}"
                                               TextWrapping="Wrap"
                                               Text="Pit lane overlays and marker callouts sit inside the same race-control canvas, styled to feel closer to F1 timing screens." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="0,0,18,0"
                    Padding="0"
                    Style="{StaticResource CardShellStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="22,18"
                            Background="{DynamicResource HeroPanelBrush}"
                            BorderBrush="{DynamicResource AppRedSoftBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="24,24,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                           Text="TRACK CONTROL" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="{Binding FocusWeekendName}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppTextMutedBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Text="{Binding StatusText}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="14,10"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource AppPanelAltBrush}"
                                    CornerRadius="16"
                                    BorderBrush="{DynamicResource AppRedSoftBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppTextMutedBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="Feed Status" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource AppRedBrush}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Text="{Binding FeedStatusBadge}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="18,16,18,0"
                            Padding="14,12"
                            Background="{DynamicResource AppPanelRaisedBrush}"
                            CornerRadius="18"
                            BorderBrush="#20FFFFFF"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="Map Zoom" />

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                <Button Style="{StaticResource ZoomButtonStyle}" Click="ZoomOut_Click" Content="-" Width="34" />
                                <Button Style="{StaticResource ZoomButtonStyle}" Click="ZoomReset_Click" Content="Fit" MinWidth="56" />
                                <Button Style="{StaticResource ZoomButtonStyle}" Click="ZoomIn_Click" Content="+" Width="34" />
                                <Slider Width="200"
                                        Margin="4,0,0,0"
                                        Minimum="0.75"
                                        Maximum="1.85"
                                        TickFrequency="0.05"
                                        Value="{Binding MapZoom, Mode=TwoWay}" />
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Text="{Binding MapZoomLabel}" />
                        </Grid>
                    </Border>
                    <Border Grid.Row="2"
                            Margin="18,16,18,0"
                            Padding="14"
                            Background="{DynamicResource AppTrackShellBrush}"
                            CornerRadius="24"
                            BorderBrush="#1AFFFFFF"
                            BorderThickness="1"
                            ClipToBounds="True">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="{Binding MapZoom}" ScaleY="{Binding MapZoom}" />
                            </Grid.RenderTransform>

                            <Border Background="#0A0B0E"
                                    CornerRadius="18" />

                            <Canvas IsHitTestVisible="False">
                                <Rectangle Width="960"
                                           Height="620"
                                           Fill="#00000000"
                                           Stroke="{DynamicResource AppCanvasFrameBrush}"
                                           StrokeThickness="1"
                                           RadiusX="16"
                                           RadiusY="16" />

                            </Canvas>

                            <Viewbox Stretch="Uniform">
                                <Grid Width="960" Height="620">
                                    <Canvas Width="960" Height="620">
                                        <Path Data="{Binding TrackGeometry}"
                                              Stroke="{DynamicResource AppTrackOutlineBrush}"
                                              StrokeThickness="38"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="{Binding TrackGeometry}"
                                              Stroke="{DynamicResource AppTrackGlowBrush}"
                                              StrokeThickness="27"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="{Binding TrackGeometry}"
                                              Stroke="{DynamicResource AppTrackLaneBrush}"
                                              StrokeThickness="16"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="{Binding TrackGeometry}"
                                              Stroke="{DynamicResource AppTrackEdgeBrush}"
                                              StrokeThickness="6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="{Binding PitLaneGeometry}"
                                              Stroke="{DynamicResource AppPitBaseBrush}"
                                              StrokeThickness="13"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                        <Path Data="{Binding PitLaneGeometry}"
                                              Stroke="{DynamicResource AppPitDashBrush}"
                                              StrokeThickness="6"
                                              StrokeDashArray="5,4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                    </Canvas>

                                    <ItemsControl ItemsSource="{Binding SectorMarkers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="960" Height="620" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                <Setter Property="Panel.ZIndex" Value="3" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Border Width="40"
                                                            Height="40"
                                                            CornerRadius="20"
                                                            Background="{Binding AccentBrush}"
                                                            BorderBrush="#B0FFFFFF"
                                                            BorderThickness="2">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource AppAccentContrastBrush}"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding Title}" />
                                                    </Border>
                                                    <TextBlock Margin="-6,6,0,0"
                                                               Foreground="{DynamicResource AppTextBrush}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Subtitle}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl ItemsSource="{Binding TurnMarkers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="960" Height="620" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                <Setter Property="Panel.ZIndex" Value="2" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,5"
                                                        Background="{DynamicResource AppTurnCardBrush}"
                                                        CornerRadius="12"
                                                        BorderBrush="#2AFFFFFF"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   Text="{Binding Title}" />
                                                        <TextBlock Foreground="{DynamicResource AppTextMutedBrush}"
                                                                   FontSize="10"
                                                                   Text="{Binding Subtitle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding Drivers}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Width="960" Height="620" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                <Setter Property="Panel.ZIndex" Value="5" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="5,4"
                                                        Background="{Binding SurfaceBrush}"
                                                        CornerRadius="11"
                                                        BorderBrush="{Binding AccentBrush}"
                                                        BorderThickness="2">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="12"
                                                                          Direction="270"
                                                                          Opacity="0.34"
                                                                          ShadowDepth="2" />
                                                    </Border.Effect>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="34"
                                                                Height="22"
                                                                Padding="5,4"
                                                                CornerRadius="7"
                                                                Background="{Binding LogoPlateBrush}">
                                                            <Image Source="{Binding TeamLogoPath}"
                                                                   Stretch="Uniform"
                                                                   SnapsToDevicePixels="True"
                                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                                        </Border>
                                                        <StackPanel Margin="6,0,0,0">
                                                            <TextBlock Foreground="{Binding PrimaryTextBrush}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Text="{Binding Code}" />
                                                            <TextBlock Foreground="{Binding SecondaryTextBrush}"
                                                                       FontSize="8"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding PositionLabel}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <DockPanel Grid.Row="3" Margin="22,16,22,18">
                        <TextBlock DockPanel.Dock="Left"
                                   Foreground="{DynamicResource AppTextMutedBrush}"
                                   FontSize="12"
                                   Text="{Binding FooterHint}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="{Binding LastUpdatedLabel}" />
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="0"
                    Style="{StaticResource CardShellStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="22,20,22,18"
                            Background="{DynamicResource HeroPanelBrush}"
                            BorderBrush="{DynamicResource AppRedSoftBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="24,24,0,0">
                        <StackPanel>
                            <TextBlock FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextBrush}"
                                       Text="Leaderboard" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource BodyStyle}"
                                       TextWrapping="Wrap"
                                       Text="Team-colored timing cards now sit inside a cleaner F1-inspired race-control panel with stronger contrast and sharper edges." />
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="18,18,18,18"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Drivers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="15"
                                            Background="{Binding SurfaceBrush}"
                                            CornerRadius="18"
                                            BorderBrush="{Binding AccentBrush}"
                                            BorderThickness="1.4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="46" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Width="40"
                                                    Height="40"
                                                    CornerRadius="20"
                                                    Background="{Binding AccentBrush}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppAccentContrastBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Text="{Binding Position}" />
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Width="38"
                                                    Height="38"
                                                    Margin="8,0,0,0"
                                                    Padding="6"
                                                    CornerRadius="12"
                                                    Background="{Binding LogoPlateBrush}">
                                                <Image Source="{Binding TeamLogoPath}"
                                                       Stretch="Uniform"
                                                       SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Border>

                                            <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                                <TextBlock Foreground="{Binding PrimaryTextBrush}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Text="{Binding DriverLine}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{Binding SecondaryTextBrush}"
                                                           FontSize="13"
                                                           Text="{Binding TeamLine}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                                                <TextBlock HorizontalAlignment="Right"
                                                           Foreground="{Binding PrimaryTextBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding GapText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           HorizontalAlignment="Right"
                                                           Foreground="{Binding SecondaryTextBrush}"
                                                           FontSize="12"
                                                           Text="{Binding SpeedText}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>







